export function getScripture(reference, version = 'KJV') {
  const quickRef = QUICK_SCRPTURES[reference];
  if (quickRef) {
    const versionKey = version.toLowerCase();
    const langText = quickRef[versionKey] || quickRef['kjv'];
    return {
      text: langText || quickRef['kjv'],
      reference,
      version,
    };
  }
  
  // For non-quick scriptures, return a fetch instruction
  return {
    needsFetch: true,
    reference,
    version,
  };
}

