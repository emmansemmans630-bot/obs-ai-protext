// Replace handleToggleVisibility:
const handleToggleVisibility = () => {
  if (state.isVisible) {
    hideOverlay();
  } else {
    // Re-show with current content
    showOverlay(state.content);
  }
  updateState((prev) => ({ ...prev, isVisible: !prev.isVisible }));
};

// Replace handleClear:
const handleClear = () => {
  hideOverlay();
  updateState((prev) => ({ ...prev, isVisible: false, content: null }));
};

// Replace handleUpdateSettings with WebSocket sync:
const handleUpdateSettings = (key, value) => {
  updateState((prev) => {
    const newSettings = { ...prev.settings, [key]: value };
    // Send to server which broadcasts to overlay
    sendMessage('UPDATE_SETTINGS', newSettings);
    return { ...prev, settings: newSettings };
  });
};
